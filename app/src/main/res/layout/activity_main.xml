<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. Carica file + waveform -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btnLoad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/load_file" />

                    <TextView
                        android:id="@+id/tvFileName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:ellipsize="middle"
                        android:singleLine="true"
                        android:text="@string/no_file"
                        tools:text="track.mp3  3:42  44100Hz" />
                </LinearLayout>

                <com.masoudss.lib.WaveformSeekBar
                    android:id="@+id/waveform"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    app:wave_background_color="@color/wave_bg"
                    app:wave_corner_radius="2dp"
                    app:wave_gap="1dp"
                    app:wave_gravity="center"
                    app:wave_max_progress="1000"
                    app:wave_min_height="3dp"
                    app:wave_padding_Bottom="4dp"
                    app:wave_padding_left="2dp"
                    app:wave_padding_right="2dp"
                    app:wave_padding_top="4dp"
                    app:wave_progress="0"
                    app:wave_progress_color="@color/wave_progress"
                    app:wave_width="2dp"
                    app:marker_color="@color/cut_red"
                    app:marker_width="2dp" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00 / 00:00"
                    android:textSize="12sp"
                    android:layout_gravity="end"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. BPM + 3. Pitch + 4. Reverse -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bpm_label"
                        android:textStyle="bold"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBpm"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="120"
                            android:textSize="18sp"/>
                        <TextView
                            android:id="@+id/tvSpeedRatio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="x1.00"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderBpm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1"
                        android:valueTo="999"
                        android:stepSize="1"
                        android:value="120"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time-stretch Sonic (no pitch)"
                        android:textSize="11sp"
                        android:alpha="0.7"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pitch_label"
                        android:textStyle="bold"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPitch"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:inputType="numberSigned|numberDecimal"
                            android:text="0.0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="st"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderPitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="-12"
                        android:valueTo="12"
                        android:stepSize="0.1"
                        android:value="0"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swReverse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reverse_label" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 5. Timeline di taglio -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timeline taglio – click per marker, frecce ←→ = 1/25s"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <com.example.audiobpmeditor.CutTimelineView
                    android:id="@+id/cutTimeline"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="#F5F5F5"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btnCut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cut" />

                    <Button
                        android:id="@+id/btnErase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/erase" />

                    <TextView
                        android:id="@+id/tvMarker"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="marker: 00:00.000"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvSelection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nessuna selezione – doppio tap su segmento per selezionare"
                    android:textSize="11sp"
                    android:alpha="0.8"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 6. Transport -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/play" />
                <Button
                    android:id="@+id/btnPause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/pause" />
                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="@string/stop" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/swLoop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/loop" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 7 + 8 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                style="?attr/materialButtonOutlinedStyle"
                android:text="@string/clear" />

            <Button
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/download" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pronto."
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:paddingBottom="24dp"/>

    </LinearLayout>
</ScrollView>
